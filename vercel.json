{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "routes": [
    { "src": "/api/auth/login", "dest": "/api/auth/login.js" },
    { "src": "/api/auth/forgot-password", "dest": "/api/auth/forgot-password.js" },
    { "src": "/api/auth/reset-password", "dest": "/api/auth/reset-password.js" },
    { "src": "/api/products", "dest": "/api/products.js" },
    { "src": "/api/users", "dest": "/api/users.js" },
    { "src": "/api/analytics", "dest": "/api/analytics.js" },
    { "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf))", "dest": "/$1" },
    { "src": "/(.*)\\.html", "dest": "/$1.html" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
